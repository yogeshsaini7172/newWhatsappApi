# ─── Evolution API ───────────────────────────────────────────────────────────
# The URL of your deployed Evolution API instance
EVOLUTION_API_URL=https://your-evolution-api.onrender.com

# API key for the Evolution API (from your Evolution API dashboard / render env)
EVOLUTION_API_KEY=your_evolution_api_key_here

# The name of the WhatsApp instance you created in Evolution API
EVOLUTION_INSTANCE=your_instance_name_here

# ─── This Server ─────────────────────────────────────────────────────────────
# Port this WhatsApp server listens on
PORT=5055

# Secret token — the main backend must send this in the X-WA-Secret header
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
WA_SERVER_SECRET=change-me-to-a-strong-random-secret

# ─── Anti-Detection Timing ───────────────────────────────────────────────────
# Seconds to wait BETWEEN consecutive messages (random value in this range)
MIN_DELAY_SECONDS=8
MAX_DELAY_SECONDS=25

# Simulated typing speed in characters per second
TYPING_CHARS_PER_SECOND=7

# Minimum / maximum seconds to show "composing" presence before sending text
MIN_COMPOSING_SECONDS=2
MAX_COMPOSING_SECONDS=12

# ─── Retry ───────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BASE_DELAY=5

# ─── Phone Number ────────────────────────────────────────────────────────────
# Country code automatically prepended to 10-digit numbers
DEFAULT_COUNTRY_CODE=91
